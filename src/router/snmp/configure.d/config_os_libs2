          SSL_CTX_set_cookie_verify_cb(NULL, app_verify_cookie_cb);
        ]])],
        [AC_MSG_RESULT(yes); ac_cv_saccaq=const],
        [AC_MSG_RESULT(no)])
        AC_DEFINE_UNQUOTED([SECOND_APPVERIFY_COOKIE_CB_ARG_QUALIFIER],
