T}
.TE
.INDENT 0.0
.TP
.B BT_SCM_PKT_SEQNUM
Level \fBSOL_BLUETOOTH\fP CMSG with data:
.INDENT 7.0
.INDENT 3.5
.sp
.EX
uint16_t pkt_seqnum;
.EE
.UNINDENT
.UNINDENT
.sp
The values are equal to the \(dqPacket_Sequence_Number\(dq defined in
Core Specification v6.1, 5.4.5. HCI ISO Data packets:
.sp
 <https://www.bluetooth.com/wp\-content/uploads/Files/Specification/HTML/Core\-61/out/en/host\-controller\-interface/host\-controller\-interface\-functional\-specification.html#UUID\-9b5fb085\-278b\-5084\-ac33\-bee2839abe6b> 
.UNINDENT
.sp
Example (Enable sequence numbers):
.INDENT 0.0
.INDENT 3.5
.sp
.EX
uint32_t opt = 1;
if (setsockopt(fd, SOL_BLUETOOTH, BT_PKT_SEQNUM, &opt, sizeof(opt)) < 0)
    goto error;
.EE
.UNINDENT
.UNINDENT
.sp
Example (Read packet and its sequence number):
.INDENT 0.0
.INDENT 3.5
.sp
.EX
char data_buf[256];
uint16_t seqnum;
union {
    char buf[CMSG_SPACE(sizeof(uint16_t))];
    struct cmsghdr align;
} control;
struct iovec data = {
    .iov_base = data_buf,
    .iov_len = sizeof(data_buf),
};
struct msghdr msg = {
    .msg_iov = &data,
    .msg_iovlen = 1,
    .msg_control = control.buf,
    .msg_controllen = sizeof(control.buf),
};
struct scm_timestamping tss;

res = recvmsg(fd, &msg, 0);
if (res < 0)
    goto error;

for (cmsg = CMSG_FIRSTHDR(&msg); cmsg; cmsg = CMSG_NXTHDR(&msg, cmsg)) {
    if (cmsg\->cmsg_level == SOL_BLUETOOTH && cmsg\->cmsg_type == BT_PKT_SEQNUM)
        memcpy(&seqnum, CMSG_DATA(cmsg), sizeof(seqnum));
}
.EE
.UNINDENT
.UNINDENT
.SH SOCKET OPTIONS (SOL_SOCKET)
.sp
\fBSOL_SOCKET\fP level socket options that modify generic socket
features (\fBSO_SNDBUF\fP, \fBSO_RCVBUF\fP, etc.) have their usual
meaning, see \fBsocket(7)\fP\&.
.sp
The \fBSOL_SOCKET\fP level ISO socket options that have
Bluetooth\-specific handling in kernel are listed below.
.SS SO_TIMESTAMPING, SO_TIMESTAMP, SO_TIMESTAMPNS
.sp
See  <https://docs.kernel.org/networking/timestamping.html> 
.sp
For ISO sockets, software RX timestamps are supported.  Software TX
timestamps (SOF_TIMESTAMPING_TX_SOFTWARE) are supported since
Linux 6.15.
.sp
The software RX timestamp is the time when the kernel received the
packet from the controller driver.
.sp
The \fBSCM_TSTAMP_SND\fP timestamp is emitted when packet is sent to the
controller driver.
.sp
The \fBSCM_TSTAMP_COMPLETION\fP timestamp is emitted when controller
reports the packet completed.  Completion timestamps are only
supported on controllers that have ISO flow control.  Other TX
timestamp types are not supported.
.sp
You can use \fBSIOCETHTOOL\fP to query supported flags.
.sp
The timestamps are in \fBCLOCK_REALTIME\fP time.
.sp
Example (Enable RX timestamping):
.INDENT 0.0
.INDENT 3.5
.sp
.EX
int flags = SOF_TIMESTAMPING_SOFTWARE |
    SOF_TIMESTAMPING_RX_SOFTWARE;
setsockopt(fd, SOL_SOCKET, SO_TIMESTAMPING, &flags, sizeof(flags));
.EE
.UNINDENT
.UNINDENT
.sp
Example (Read packet and its RX timestamp):
.INDENT 0.0
.INDENT 3.5
.sp
.EX
char data_buf[256];
union {
    char buf[CMSG_SPACE(sizeof(struct scm_timestamping))];
    struct cmsghdr align;
} control;
struct iovec data = {
    .iov_base = data_buf,
    .iov_len = sizeof(data_buf),
};
struct msghdr msg = {
    .msg_iov = &data,
    .msg_iovlen = 1,
    .msg_control = control.buf,
    .msg_controllen = sizeof(control.buf),
};
struct scm_timestamping tss;

res = recvmsg(fd, &msg, MSG_ERRQUEUE | MSG_DONTWAIT);
if (res < 0)
    goto error;

for (cmsg = CMSG_FIRSTHDR(&msg); cmsg; cmsg = CMSG_NXTHDR(&msg, cmsg)) {
    if (cmsg\->cmsg_level == SOL_SOCKET && cmsg\->cmsg_type == SCM_TIMESTAMPING)
        memcpy(&tss, CMSG_DATA(cmsg), sizeof(tss));
}

tstamp_clock_realtime = tss.ts[0];
.EE
.UNINDENT
.UNINDENT
.sp
Example (Enable TX timestamping):
.INDENT 0.0
.INDENT 3.5
.sp
.EX
int flags = SOF_TIMESTAMPING_SOFTWARE |
    SOF_TIMESTAMPING_TX_SOFTWARE |
    SOF_TIMESTAMPING_OPT_ID;
setsockopt(fd, SOL_SOCKET, SO_TIMESTAMPING, &flags, sizeof(flags));
.EE
.UNINDENT
.UNINDENT
.sp
Example (Read TX timestamps):
.INDENT 0.0
.INDENT 3.5
.sp
.EX
union {
    char buf[CMSG_SPACE(sizeof(struct scm_timestamping))];
    struct cmsghdr align;
} control;
struct iovec data = {
    .iov_base = NULL,
    .iov_len = 0
};
struct msghdr msg = {
    .msg_iov = &data,
    .msg_iovlen = 1,
    .msg_control = control.buf,
    .msg_controllen = sizeof(control.buf),
};
struct cmsghdr *cmsg;
struct scm_timestamping tss;
struct sock_extended_err serr;
int res;

res = recvmsg(fd, &msg, MSG_ERRQUEUE | MSG_DONTWAIT);
if (res < 0)
    goto error;

for (cmsg = CMSG_FIRSTHDR(&msg); cmsg; cmsg = CMSG_NXTHDR(&msg, cmsg)) {
    if (cmsg\->cmsg_level == SOL_SOCKET && cmsg\->cmsg_type == SCM_TIMESTAMPING)
        memcpy(&tss, CMSG_DATA(cmsg), sizeof(tss));
    else if (cmsg\->cmsg_level == SOL_BLUETOOTH && cmsg\->cmsg_type == BT_SCM_ERROR)
        memcpy(&serr, CMSG_DATA(cmsg), sizeof(serr));
}

tstamp_clock_realtime = tss.ts[0];
tstamp_type = serr\->ee_info;      /* SCM_TSTAMP_SND or SCM_TSTAMP_COMPLETION */
tstamp_seqnum = serr\->ee_data;
.EE
