.SH IOCTLS
.sp
The following ioctls with operation specific for ISO sockets are
available.
.SS SIOCETHTOOL (since Linux 6.16\-rc1)
.sp
Supports only command \fIETHTOOL_GET_TS_INFO\fP, which may be used to
query supported \fISOF_TIMESTAMPING_*\fP flags.  The
\fISOF_TIMESTAMPING_OPT_*\fP flags are always available as applicable.
.sp
Example:
.INDENT 0.0
.INDENT 3.5
.sp
.EX
#include <linux/ethtool.h>
#include <linux/sockios.h>
#include <net/if.h>
#include <sys/socket.h>
#include <sys/ioctl.h>

\&...

struct ifreq ifr = {};
struct ethtool_ts_info cmd = {};
int sk;

snprintf(ifr.ifr_name, sizeof(ifr.ifr_name), \(dqhci0\(dq);
ifr.ifr_data = (void *)&cmd;
cmd.cmd = ETHTOOL_GET_TS_INFO;

sk = socket(PF_BLUETOOTH, SOCK_SEQPACKET, BTPROTO_ISO);
if (sk < 0)
    goto error;
if (ioctl(sk, SIOCETHTOOL, &ifr))
    goto error;

sof_available = cmd.so_timestamping;
.EE
