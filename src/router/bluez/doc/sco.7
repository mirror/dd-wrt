.SS BT_CODEC (since Linux 5.14)
.sp
Transport codec offload, possible values:
.INDENT 0.0
.INDENT 3.5
.sp
.EX
struct bt_codec {
    uint8_t id;
    uint16_t cid;
    uint16_t vid;
    uint8_t data_path_id;
    uint8_t num_caps;
    struct codec_caps {
        uint8_t len;
        uint8_t data[];
    } caps[];
} __attribute__((packed));

