Terminals unused in grammar

    "comment"
    "doc comment"
    "open tag"
    "'<?='"
    "'?>'"
    "whitespace"
    "invalid character"
    T_ERROR


Grammar

    0 $accept: start "end of file"

    1 start: top_statement_list

    2 reserved_non_modifiers: "'include'"
    3                       | "'include_once'"
    4                       | "'eval'"
    5                       | "'require'"
    6                       | "'require_once'"
    7                       | "'or'"
    8                       | "'xor'"
    9                       | "'and'"
   10                       | "'instanceof'"
   11                       | "'new'"
   12                       | "'clone'"
   13                       | "'exit'"
   14                       | "'if'"
   15                       | "'elseif'"
   16                       | "'else'"
   17                       | "'endif'"
   18                       | "'echo'"
   19                       | "'do'"
   20                       | "'while'"
   21                       | "'endwhile'"
   22                       | "'for'"
   23                       | "'endfor'"
   24                       | "'foreach'"
   25                       | "'endforeach'"
   26                       | "'declare'"
   27                       | "'enddeclare'"
   28                       | "'as'"
   29                       | "'try'"
   30                       | "'catch'"
   31                       | "'finally'"
   32                       | "'throw'"
   33                       | "'use'"
   34                       | "'insteadof'"
   35                       | "'global'"
   36                       | "'var'"
   37                       | "'unset'"
   38                       | "'isset'"
   39                       | "'empty'"
   40                       | "'continue'"
   41                       | "'goto'"
   42                       | "'function'"
   43                       | "'const'"
   44                       | "'return'"
   45                       | "'print'"
   46                       | "'yield'"
   47                       | "'list'"
   48                       | "'switch'"
   49                       | "'endswitch'"
   50                       | "'case'"
   51                       | "'default'"
   52                       | "'break'"
   53                       | "'array'"
   54                       | "'callable'"
   55                       | "'extends'"
   56                       | "'implements'"
   57                       | "'namespace'"
   58                       | "'trait'"
   59                       | "'interface'"
   60                       | "'class'"
   61                       | "'__CLASS__'"
   62                       | "'__TRAIT__'"
   63                       | "'__FUNCTION__'"
   64                       | "'__METHOD__'"
   65                       | "'__LINE__'"
   66                       | "'__FILE__'"
   67                       | "'__DIR__'"
   68                       | "'__NAMESPACE__'"
   69                       | "'fn'"
   70                       | "'match'"
   71                       | "'enum'"
   72                       | "'__PROPERTY__'"

   73 semi_reserved: reserved_non_modifiers
   74              | "'static'"
   75              | "'abstract'"
   76              | "'final'"
   77              | "'private'"
   78              | "'protected'"
   79              | "'public'"
   80              | "'readonly'"

   81 ampersand: "'&'"
   82          | "amp"

   83 identifier: "identifier"
   84           | semi_reserved

   85 top_statement_list: top_statement_list top_statement
   86                   | %empty

   87 namespace_declaration_name: identifier
   88                           | "namespaced name"

   89 namespace_name: "identifier"
   90               | "namespaced name"

   91 legacy_namespace_name: namespace_name
   92                      | "fully qualified name"

   93 name: "identifier"
   94     | "namespaced name"
   95     | "fully qualified name"
   96     | "namespace-relative name"

   97 attribute_decl: class_name
   98               | class_name argument_list

   99 attribute_group: attribute_decl
  100                | attribute_group ',' attribute_decl

  101 attribute: "'#['" backup_doc_comment attribute_group possible_comma ']'

  102 attributes: attribute
  103           | attributes attribute

  104 attributed_statement: function_declaration_statement
  105                     | class_declaration_statement
  106                     | trait_declaration_statement
  107                     | interface_declaration_statement
  108                     | enum_declaration_statement

  109 attributed_top_statement: attributed_statement
  110                         | "'const'" const_list ';'

  111 top_statement: statement
  112              | attributed_top_statement
  113              | attributes attributed_top_statement
  114              | "'__halt_compiler'" '(' ')' ';'
  115              | "'namespace'" namespace_declaration_name ';'

  116 $@1: %empty

  117 top_statement: "'namespace'" namespace_declaration_name $@1 '{' top_statement_list '}'

  118 $@2: %empty

  119 top_statement: "'namespace'" $@2 '{' top_statement_list '}'
  120              | "'use'" mixed_group_use_declaration ';'
  121              | "'use'" use_type group_use_declaration ';'
  122              | "'use'" use_declarations ';'
  123              | "'use'" use_type use_declarations ';'

  124 use_type: "'function'"
  125         | "'const'"

  126 group_use_declaration: legacy_namespace_name "'\\'" '{' unprefixed_use_declarations possible_comma '}'

  127 mixed_group_use_declaration: legacy_namespace_name "'\\'" '{' inline_use_declarations possible_comma '}'

  128 possible_comma: %empty
  129               | ','

  130 inline_use_declarations: inline_use_declarations ',' inline_use_declaration
  131                        | inline_use_declaration

  132 unprefixed_use_declarations: unprefixed_use_declarations ',' unprefixed_use_declaration
  133                            | unprefixed_use_declaration

  134 use_declarations: use_declarations ',' use_declaration
  135                 | use_declaration

  136 inline_use_declaration: unprefixed_use_declaration
  137                       | use_type unprefixed_use_declaration

  138 unprefixed_use_declaration: namespace_name
  139                           | namespace_name "'as'" "identifier"

  140 use_declaration: legacy_namespace_name
  141                | legacy_namespace_name "'as'" "identifier"

  142 const_list: const_list ',' const_decl
  143           | const_decl

  144 inner_statement_list: inner_statement_list inner_statement
  145                     | %empty

  146 inner_statement: statement
  147                | attributed_statement
  148                | attributes attributed_statement
  149                | "'__halt_compiler'" '(' ')' ';'

  150 statement: '{' inner_statement_list '}'
  151          | if_stmt
  152          | alt_if_stmt
  153          | "'while'" '(' expr ')' while_statement
  154          | "'do'" statement "'while'" '(' expr ')' ';'
  155          | "'for'" '(' for_exprs ';' for_cond_exprs ';' for_exprs ')' for_statement
  156          | "'switch'" '(' expr ')' switch_case_list
  157          | "'break'" optional_expr ';'
  158          | "'continue'" optional_expr ';'
  159          | "'return'" optional_expr ';'
  160          | "'global'" global_var_list ';'
  161          | "'static'" static_var_list ';'
  162          | "'echo'" echo_expr_list ';'
  163          | T_INLINE_HTML
  164          | expr ';'
  165          | "'unset'" '(' unset_variables possible_comma ')' ';'
  166          | "'foreach'" '(' expr "'as'" foreach_variable ')' foreach_statement
  167          | "'foreach'" '(' expr "'as'" foreach_variable "'=>'" foreach_variable ')' foreach_statement

  168 $@3: %empty

  169 statement: "'declare'" '(' const_list ')' $@3 declare_statement
  170          | ';'
  171          | "'try'" '{' inner_statement_list '}' catch_list finally_statement
  172          | "'goto'" "identifier" ';'
  173          | "identifier" ':'
  174          | "'(void)'" expr ';'

  175 catch_list: %empty
  176           | catch_list "'catch'" '(' catch_name_list optional_variable ')' '{' inner_statement_list '}'

  177 catch_name_list: class_name
  178                | catch_name_list '|' class_name

  179 optional_variable: %empty
  180                  | "variable"

  181 finally_statement: %empty
  182                  | "'finally'" '{' inner_statement_list '}'

  183 unset_variables: unset_variable
  184                | unset_variables ',' unset_variable

  185 unset_variable: variable

  186 function_name: "identifier"
  187              | "'readonly'"

  188 function_declaration_statement: function returns_ref function_name backup_doc_comment '(' parameter_list ')' return_type backup_fn_flags '{' inner_statement_list '}' backup_fn_flags

  189 is_reference: %empty
  190             | "'&'"

  191 is_variadic: %empty
  192            | "'...'"

  193 @4: %empty

  194 class_declaration_statement: class_modifiers "'class'" @4 "identifier" extends_from implements_list backup_doc_comment '{' class_statement_list '}'

  195 @5: %empty

  196 class_declaration_statement: "'class'" @5 "identifier" extends_from implements_list backup_doc_comment '{' class_statement_list '}'

  197 class_modifiers: class_modifier
  198                | class_modifiers class_modifier

  199 anonymous_class_modifiers: class_modifier
  200                          | anonymous_class_modifiers class_modifier

  201 anonymous_class_modifiers_optional: %empty
  202                                   | anonymous_class_modifiers

  203 class_modifier: "'abstract'"
  204               | "'final'"
  205               | "'readonly'"

  206 @6: %empty

  207 trait_declaration_statement: "'trait'" @6 "identifier" backup_doc_comment '{' class_statement_list '}'

  208 @7: %empty

  209 interface_declaration_statement: "'interface'" @7 "identifier" interface_extends_list backup_doc_comment '{' class_statement_list '}'

  210 @8: %empty

  211 enum_declaration_statement: "'enum'" @8 "identifier" enum_backing_type implements_list backup_doc_comment '{' class_statement_list '}'

  212 enum_backing_type: %empty
  213                  | ':' type_expr

  214 enum_case: "'case'" backup_doc_comment identifier enum_case_expr ';'

  215 enum_case_expr: %empty
  216               | '=' expr

  217 extends_from: %empty
  218             | "'extends'" class_name

  219 interface_extends_list: %empty
  220                       | "'extends'" class_name_list

  221 implements_list: %empty
  222                | "'implements'" class_name_list

  223 foreach_variable: variable
  224                 | ampersand variable
  225                 | "'list'" '(' array_pair_list ')'
  226                 | '[' array_pair_list ']'

  227 for_statement: statement
  228              | ':' inner_statement_list "'endfor'" ';'

  229 foreach_statement: statement
  230                  | ':' inner_statement_list "'endforeach'" ';'

  231 declare_statement: statement
  232                  | ':' inner_statement_list "'enddeclare'" ';'

  233 switch_case_list: '{' case_list '}'
  234                 | '{' ';' case_list '}'
  235                 | ':' case_list "'endswitch'" ';'
  236                 | ':' ';' case_list "'endswitch'" ';'

  237 case_list: %empty
  238          | case_list "'case'" expr ':' inner_statement_list
  239          | case_list "'case'" expr ';' inner_statement_list
  240          | case_list "'default'" ':' inner_statement_list
  241          | case_list "'default'" ';' inner_statement_list

  242 match: "'match'" '(' expr ')' '{' match_arm_list '}'

  243 match_arm_list: %empty
  244               | non_empty_match_arm_list possible_comma

  245 non_empty_match_arm_list: match_arm
  246                         | non_empty_match_arm_list ',' match_arm

  247 match_arm: match_arm_cond_list possible_comma "'=>'" expr
  248          | "'default'" possible_comma "'=>'" expr

  249 match_arm_cond_list: expr
  250                    | match_arm_cond_list ',' expr

  251 while_statement: statement
  252                | ':' inner_statement_list "'endwhile'" ';'

  253 if_stmt_without_else: "'if'" '(' expr ')' statement
  254                     | if_stmt_without_else "'elseif'" '(' expr ')' statement

  255 if_stmt: if_stmt_without_else
  256        | if_stmt_without_else "'else'" statement

  257 alt_if_stmt_without_else: "'if'" '(' expr ')' ':' inner_statement_list
  258                         | alt_if_stmt_without_else "'elseif'" '(' expr ')' ':' inner_statement_list

  259 alt_if_stmt: alt_if_stmt_without_else "'endif'" ';'
  260            | alt_if_stmt_without_else "'else'" ':' inner_statement_list "'endif'" ';'

  261 parameter_list: non_empty_parameter_list possible_comma
  262               | %empty

  263 non_empty_parameter_list: attributed_parameter
  264                         | non_empty_parameter_list ',' attributed_parameter

  265 attributed_parameter: attributes parameter
  266                     | parameter

  267 optional_cpp_modifiers: %empty
  268                       | non_empty_member_modifiers

  269 parameter: optional_cpp_modifiers optional_type_without_static is_reference is_variadic "variable" backup_doc_comment optional_property_hook_list
  270          | optional_cpp_modifiers optional_type_without_static is_reference is_variadic "variable" backup_doc_comment '=' expr optional_property_hook_list

  271 optional_type_without_static: %empty
  272                             | type_expr_without_static

  273 type_expr: type
  274          | '?' type
  275          | union_type
  276          | intersection_type

  277 type: type_without_static
  278     | "'static'"

  279 union_type_element: type
  280                   | '(' intersection_type ')'

  281 union_type: union_type_element '|' union_type_element
  282           | union_type '|' union_type_element

  283 intersection_type: type "amp" type
  284                  | intersection_type "amp" type

  285 type_expr_without_static: type_without_static
  286                         | '?' type_without_static
  287                         | union_type_without_static
  288                         | intersection_type_without_static

  289 type_without_static: "'array'"
  290                    | "'callable'"
  291                    | name

  292 union_type_without_static_element: type_without_static
  293                                  | '(' intersection_type_without_static ')'

  294 union_type_without_static: union_type_without_static_element '|' union_type_without_static_element
  295                          | union_type_without_static '|' union_type_without_static_element

  296 intersection_type_without_static: type_without_static "amp" type_without_static
  297                                 | intersection_type_without_static "amp" type_without_static

  298 return_type: %empty
  299            | ':' type_expr

  300 argument_list: '(' ')'
  301              | '(' non_empty_argument_list possible_comma ')'
  302              | '(' "'...'" ')'

  303 non_empty_argument_list: argument
  304                        | non_empty_argument_list ',' argument

  305 clone_argument_list: '(' ')'
  306                    | '(' non_empty_clone_argument_list possible_comma ')'
  307                    | '(' expr ',' ')'
  308                    | '(' "'...'" ')'

  309 non_empty_clone_argument_list: expr ',' argument
  310                              | argument_no_expr
  311                              | non_empty_clone_argument_list ',' argument

  312 argument_no_expr: identifier ':' expr
  313                 | "'...'" expr

  314 argument: expr
  315         | argument_no_expr

  316 global_var_list: global_var_list ',' global_var
  317                | global_var

  318 global_var: simple_variable

  319 static_var_list: static_var_list ',' static_var
  320                | static_var

  321 static_var: "variable"
  322           | "variable" '=' expr

  323 class_statement_list: class_statement_list class_statement
  324                     | %empty

  325 attributed_class_statement: property_modifiers optional_type_without_static property_list ';'
  326                           | property_modifiers optional_type_without_static hooked_property
  327                           | class_const_modifiers "'const'" class_const_list ';'
  328                           | class_const_modifiers "'const'" type_expr class_const_list ';'
  329                           | method_modifiers function returns_ref identifier backup_doc_comment '(' parameter_list ')' return_type backup_fn_flags method_body backup_fn_flags
  330                           | enum_case

  331 class_statement: attributed_class_statement
  332                | attributes attributed_class_statement
  333                | "'use'" class_name_list trait_adaptations

  334 class_name_list: class_name
  335                | class_name_list ',' class_name

  336 trait_adaptations: ';'
  337                  | '{' '}'
  338                  | '{' trait_adaptation_list '}'

  339 trait_adaptation_list: trait_adaptation
  340                      | trait_adaptation_list trait_adaptation

  341 trait_adaptation: trait_precedence ';'
  342                 | trait_alias ';'

  343 trait_precedence: absolute_trait_method_reference "'insteadof'" class_name_list

  344 trait_alias: trait_method_reference "'as'" "identifier"
  345            | trait_method_reference "'as'" reserved_non_modifiers
  346            | trait_method_reference "'as'" member_modifier identifier
  347            | trait_method_reference "'as'" member_modifier

  348 trait_method_reference: identifier
  349                       | absolute_trait_method_reference

  350 absolute_trait_method_reference: class_name "'::'" identifier

  351 method_body: ';'
  352            | '{' inner_statement_list '}'

  353 property_modifiers: non_empty_member_modifiers
  354                   | "'var'"

  355 method_modifiers: %empty
  356                 | non_empty_member_modifiers

  357 class_const_modifiers: %empty
  358                      | non_empty_member_modifiers

  359 non_empty_member_modifiers: member_modifier
  360                           | non_empty_member_modifiers member_modifier

  361 member_modifier: "'public'"
  362                | "'protected'"
  363                | "'private'"
  364                | "'public(set)'"
  365                | "'protected(set)'"
  366                | "'private(set)'"
  367                | "'static'"
  368                | "'abstract'"
  369                | "'final'"
  370                | "'readonly'"

  371 property_list: property_list ',' property
  372              | property

  373 property: "variable" backup_doc_comment
  374         | "variable" '=' expr backup_doc_comment

  375 hooked_property: "variable" backup_doc_comment '{' property_hook_list '}'
  376                | "variable" '=' expr backup_doc_comment '{' property_hook_list '}'

  377 property_hook_list: %empty
  378                   | property_hook_list property_hook
  379                   | property_hook_list attributes property_hook

  380 optional_property_hook_list: %empty
  381                            | '{' property_hook_list '}'

  382 property_hook_modifiers: %empty
  383                        | non_empty_member_modifiers

  384 @9: %empty

  385 property_hook: property_hook_modifiers returns_ref "identifier" backup_doc_comment @9 optional_parameter_list backup_fn_flags property_hook_body backup_fn_flags

  386 property_hook_body: ';'
  387                   | '{' inner_statement_list '}'
  388                   | "'=>'" expr ';'

  389 optional_parameter_list: %empty
  390                        | '(' parameter_list ')'

  391 class_const_list: class_const_list ',' class_const_decl
  392                 | class_const_decl

  393 class_const_decl: "identifier" '=' expr backup_doc_comment
  394                 | semi_reserved '=' expr backup_doc_comment

  395 const_decl: "identifier" '=' expr backup_doc_comment

  396 echo_expr_list: echo_expr_list ',' echo_expr
  397               | echo_expr

  398 echo_expr: expr

  399 for_cond_exprs: %empty
  400               | non_empty_for_exprs ',' expr
  401               | expr

  402 for_exprs: %empty
  403          | non_empty_for_exprs

  404 non_empty_for_exprs: non_empty_for_exprs ',' expr
  405                    | non_empty_for_exprs ',' "'(void)'" expr
  406                    | "'(void)'" expr
  407                    | expr

  408 @10: %empty

  409 anonymous_class: anonymous_class_modifiers_optional "'class'" @10 ctor_arguments extends_from implements_list backup_doc_comment '{' class_statement_list '}'

  410 new_dereferenceable: "'new'" class_name_reference argument_list
  411                    | "'new'" anonymous_class
  412                    | "'new'" attributes anonymous_class

  413 new_non_dereferenceable: "'new'" class_name_reference

  414 expr: variable
  415     | "'list'" '(' array_pair_list ')' '=' expr
  416     | '[' array_pair_list ']' '=' expr
  417     | variable '=' expr
  418     | variable '=' ampersand variable
  419     | "'clone'" clone_argument_list
  420     | "'clone'" expr
  421     | variable "'+='" expr
  422     | variable "'-='" expr
  423     | variable "'*='" expr
  424     | variable "'**='" expr
  425     | variable "'/='" expr
  426     | variable "'.='" expr
  427     | variable "'%='" expr
  428     | variable "'&='" expr
  429     | variable "'|='" expr
  430     | variable "'^='" expr
  431     | variable "'<<='" expr
  432     | variable "'>>='" expr
  433     | variable "'??='" expr
  434     | variable "'++'"
  435     | "'++'" variable
  436     | variable "'--'"
  437     | "'--'" variable
  438     | expr "'||'" expr
  439     | expr "'&&'" expr
  440     | expr "'or'" expr
  441     | expr "'and'" expr
  442     | expr "'xor'" expr
  443     | expr '|' expr
  444     | expr "amp" expr
  445     | expr "'&'" expr
  446     | expr '^' expr
  447     | expr '.' expr
  448     | expr '+' expr
  449     | expr '-' expr
  450     | expr '*' expr
  451     | expr "'**'" expr
  452     | expr '/' expr
  453     | expr '%' expr
  454     | expr "'<<'" expr
  455     | expr "'>>'" expr
  456     | '+' expr
  457     | '-' expr
  458     | '!' expr
  459     | '~' expr
  460     | expr "'==='" expr
  461     | expr "'!=='" expr
  462     | expr "'=='" expr
  463     | expr "'!='" expr
  464     | expr "'|>'" expr
  465     | expr '<' expr
  466     | expr "'<='" expr
  467     | expr '>' expr
  468     | expr "'>='" expr
  469     | expr "'<=>'" expr
  470     | expr "'instanceof'" class_name_reference
  471     | '(' expr ')'
  472     | new_dereferenceable
  473     | new_non_dereferenceable
  474     | expr '?' expr ':' expr
  475     | expr '?' ':' expr
  476     | expr "'??'" expr
  477     | internal_functions_in_yacc
  478     | "'(int)'" expr
  479     | "'(float)'" expr
  480     | "'(string)'" expr
  481     | "'(array)'" expr
  482     | "'(object)'" expr
  483     | "'(bool)'" expr
  484     | "'(unset)'" expr
  485     | "'exit'" ctor_arguments
  486     | '@' expr
  487     | scalar
  488     | '`' backticks_expr '`'
  489     | "'print'" expr
  490     | "'yield'"
  491     | "'yield'" expr
  492     | "'yield'" expr "'=>'" expr
  493     | "'yield from'" expr
  494     | "'throw'" expr
  495     | inline_function
  496     | attributes inline_function
  497     | "'static'" inline_function
  498     | attributes "'static'" inline_function
  499     | match

  500 inline_function: function returns_ref backup_doc_comment '(' parameter_list ')' lexical_vars return_type backup_fn_flags '{' inner_statement_list '}' backup_fn_flags
  501                | fn returns_ref backup_doc_comment '(' parameter_list ')' return_type "'=>'" backup_fn_flags backup_lex_pos expr backup_fn_flags

  502 fn: "'fn'"

  503 function: "'function'"

  504 backup_doc_comment: %empty

  505 backup_fn_flags: %empty

  506 backup_lex_pos: %empty

  507 returns_ref: %empty
  508            | ampersand

  509 lexical_vars: %empty
  510             | "'use'" '(' lexical_var_list possible_comma ')'

  511 lexical_var_list: lexical_var_list ',' lexical_var
  512                 | lexical_var

  513 lexical_var: "variable"
  514            | ampersand "variable"

  515 function_call: name argument_list
  516              | "'readonly'" argument_list
  517              | class_name "'::'" member_name argument_list
  518              | variable_class_name "'::'" member_name argument_list

  519 @11: %empty

  520 function_call: callable_expr @11 argument_list

  521 class_name: "'static'"
  522           | name

  523 class_name_reference: class_name
  524                     | new_variable
  525                     | '(' expr ')'

  526 backticks_expr: %empty
  527               | "string content"
  528               | encaps_list

  529 ctor_arguments: %empty
  530               | argument_list

  531 dereferenceable_scalar: "'array'" '(' array_pair_list ')'
  532                       | '[' array_pair_list ']'
  533                       | "quoted string"
  534                       | '"' encaps_list '"'

  535 scalar: "integer"
  536       | "floating-point number"
  537       | "heredoc start" "string content" "heredoc end"
  538       | "heredoc start" "heredoc end"
  539       | "heredoc start" encaps_list "heredoc end"
  540       | dereferenceable_scalar
  541       | constant
  542       | class_constant

  543 constant: name
  544         | "'__LINE__'"
  545         | "'__FILE__'"
  546         | "'__DIR__'"
  547         | "'__TRAIT__'"
  548         | "'__METHOD__'"
  549         | "'__FUNCTION__'"
  550         | "'__PROPERTY__'"
  551         | "'__NAMESPACE__'"
  552         | "'__CLASS__'"

  553 class_constant: class_name "'::'" identifier
  554               | variable_class_name "'::'" identifier
  555               | class_name "'::'" '{' expr '}'
  556               | variable_class_name "'::'" '{' expr '}'

  557 optional_expr: %empty
  558              | expr

  559 variable_class_name: fully_dereferenceable

  560 fully_dereferenceable: variable
  561                      | '(' expr ')'
  562                      | dereferenceable_scalar
  563                      | class_constant
  564                      | new_dereferenceable

  565 array_object_dereferenceable: fully_dereferenceable
  566                             | constant

  567 callable_expr: callable_variable
  568              | '(' expr ')'
  569              | dereferenceable_scalar
  570              | new_dereferenceable

  571 callable_variable: simple_variable
  572                  | array_object_dereferenceable '[' optional_expr ']'
  573                  | array_object_dereferenceable "'->'" property_name argument_list
  574                  | array_object_dereferenceable "'?->'" property_name argument_list
  575                  | function_call

  576 variable: callable_variable
  577         | static_member
  578         | array_object_dereferenceable "'->'" property_name
  579         | array_object_dereferenceable "'?->'" property_name

  580 simple_variable: "variable"
  581                | '$' '{' expr '}'
  582                | '$' simple_variable

  583 static_member: class_name "'::'" simple_variable
  584              | variable_class_name "'::'" simple_variable

  585 new_variable: simple_variable
  586             | new_variable '[' optional_expr ']'
  587             | new_variable "'->'" property_name
  588             | new_variable "'?->'" property_name
  589             | class_name "'::'" simple_variable
  590             | new_variable "'::'" simple_variable

  591 member_name: identifier
  592            | '{' expr '}'
  593            | simple_variable

  594 property_name: "identifier"
  595              | '{' expr '}'
  596              | simple_variable

  597 array_pair_list: non_empty_array_pair_list

  598 possible_array_pair: %empty
  599                    | array_pair

  600 non_empty_array_pair_list: non_empty_array_pair_list ',' possible_array_pair
  601                          | possible_array_pair

  602 array_pair: expr "'=>'" expr
  603           | expr
  604           | expr "'=>'" ampersand variable
  605           | ampersand variable
  606           | "'...'" expr
  607           | expr "'=>'" "'list'" '(' array_pair_list ')'
  608           | "'list'" '(' array_pair_list ')'

  609 encaps_list: encaps_list encaps_var
  610            | encaps_list "string content"
  611            | encaps_var
  612            | "string content" encaps_var

  613 encaps_var: "variable"
  614           | "variable" '[' encaps_var_offset ']'
  615           | "variable" "'->'" "identifier"
  616           | "variable" "'?->'" "identifier"
  617           | "'${'" expr '}'
  618           | "'${'" "variable name" '}'
  619           | "'${'" "variable name" '[' expr ']' '}'
  620           | "'{$'" variable '}'

  621 encaps_var_offset: "identifier"
  622                  | "number"
  623                  | '-' "number"
  624                  | "variable"

  625 internal_functions_in_yacc: "'isset'" '(' isset_variables possible_comma ')'
  626                           | "'empty'" '(' expr ')'
  627                           | "'include'" expr
  628                           | "'include_once'" expr
  629                           | "'eval'" '(' expr ')'
  630                           | "'require'" expr
  631                           | "'require_once'" expr

  632 isset_variables: isset_variable
  633                | isset_variables ',' isset_variable

  634 isset_variable: expr


