				qcom,port_phyinfo {

					port@0 {
						port_id = <0x1>;
						phy_address = <0x1>;
					};

					port@1 {
						port_id = <0x2>;
						phy_address = <0x2>;
					};

					port@2 {
						port_id = <0x3>;
						phy_address = <0x3>;
					};

					port@3 {
						port_id = <0x4>;
						phy_address = <0x4>;
					};

					port@4 {
						port_id = <0x5>;
						phy_address = <0x8>;
