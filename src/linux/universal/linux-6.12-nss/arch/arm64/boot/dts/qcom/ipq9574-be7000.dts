					};

					port@5 {
						port_id = <0x6>;
						phy_address = <0x0>;
						ethernet-phy-ieee802.3-c45;
					};
				};

				led_source@0 {
					source = <0x0>;
					mode = "normal";
					speed = "all";
					blink_en = "enable";
					active = "high";
				};

				led_source@3 {
