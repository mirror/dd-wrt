			gpios = <&tlmm 43 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};
	};*/

	clocks {
		qca8k_uniphy0_rx: qca8k-uniphy0-rx {
			compatible = "fixed-clock";
			clock-frequency = <312500000>;
			#clock-cells = <0>;
		};

		qca8k_uniphy0_tx: qca8k-uniphy0-tx {
			compatible = "fixed-clock";
			clock-frequency = <312500000>;
			#clock-cells = <0>;
		};

		qca8k_uniphy1_rx: qca8k-uniphy1-rx {
			compatible = "fixed-clock";
			clock-frequency = <312500000>;
			#clock-cells = <0>;
		};

		qca8k_uniphy1_tx: qca8k-uniphy1-tx {
			compatible = "fixed-clock";
			clock-frequency = <312500000>;
			#clock-cells = <0>;
		};

		qca8k_uniphy1_rx312p5m: qca8k-uniphy1-rx312p5m {
			compatible = "fixed-clock";
			clock-frequency = <312500000>;
			#clock-cells = <0>;
		};

		qca8k_uniphy1_tx312p5m: qca8k-uniphy1-tx312p5m {
			compatible = "fixed-clock";
			clock-frequency = <312500000>;
			#clock-cells = <0>;
		};
	};


