		};

		qca8k_uniphy0_tx: qca8k-uniphy0-tx {
			compatible = "fixed-clock";
			clock-frequency = <312500000>;
			#clock-cells = <0>;
		};
	};*/
};

&blsp1_i2c1 {
	pinctrl-0 = <&i2c1_pins>;
	pinctrl-names = "default";
	status = "okay";

	nfc: nfc@54 {
		compatible = "miwifi,nfc";
		reg = <0x54>;
	};
};

&blsp1_i2c3 {
	pinctrl-0 = <&i2c3_pins>;
	pinctrl-names = "default";
	status = "okay";

};

&blsp1_uart2 {
	pinctrl-0 = <&uart2_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&blsp1_uart3 {
	pinctrl-0 = <&uart3_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&blsp1_uart4 {
	pinctrl-0 = <&uart4_pins>;
	pinctrl-names = "default";
	status = "okay";
};


