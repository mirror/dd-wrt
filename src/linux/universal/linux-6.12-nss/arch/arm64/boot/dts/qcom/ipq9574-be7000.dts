&sleep_clk {
	clock-frequency = <32000>;
};


&q6_region {
	status = "okay";
};

&m3_dump {
	status = "okay";
};

&q6_caldb_region {
	status = "okay";
};

&q6_etr_dump {
	status = "okay";
};


&wifi {
	status = "okay";
	qcom,ath11k-calibration-variant = "Xiaomi-BE7000";
	qcom,bdf-addr = <0x4b700000>;
	qcom,caldb-addr = <0x4d800000>;
	qcom,caldb-size = <0x500000>;
	qcom,m3-dump-addr = <0x4d600000>;
	qcom,board_id = <0x20>;
};

&qcn9224_pci2 {
	status = "okay";
};

&pcie2_x2 {
	pinctrl-0 = <&pcie2_default>;
	pinctrl-names = "default";

	perst-gpios = <&tlmm 29 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 30 GPIO_ACTIVE_LOW>;
	status = "okay";

	pcie@0,0 {
		#address-cells = <3>;
		#size-cells = <2>;
		reg = <0 0 0 0 0>;

		wifi6: pcie@0 {
			compatible = "pci17cb,1109";
			reg = <0 0 0 0 0>;
			qcom,board_id = <0x2>;
/*			qcom,board_id = <0x1008>;*/
			hremote_node = <&qcn9224_pci2>;
			qcom,num-radios = <1>;
		};
	};

};

&pcie2_phy {
	status = "okay";
};


&tlmm {
	i2c1_pins: i2c1-state {
		pins = "gpio36", "gpio37";
		function = "blsp1_i2c";
		drive-strength = <8>;
		bias-disable;
	};

	i2c3_pins: i2c3-state {
		pins = "gpio15", "gpio16";
		function = "blsp3_i2c";
		drive-strength = <0x8>;
		bias-disable;
		phandle = <0x1f>;
	};

	gpio_keys_default: gpio-keys-default-state {
		pins = "gpio44";
		function = "gpio";
		drive-strength = <8>;
		bias-pull-up;
	};

	gpio_leds_default: gpio-leds-default-state {
		pins = "gpio8", "gpio40", "gpio41", "gpio42", "gpio43";
		function = "gpio";
		drive-strength = <8>;
		bias-pull-up;
	};
	gps_pins {
		uart3_pins: blsp3_uart_pinmux {
			pins = "gpio17", "gpio18";
			function = "blsp3_uart";
			drive-strength = <0x8>;
			bias-disable;
		};

		gps_on_off {
			pins = "gpio7";
			function = "gpio";
			drive-strength = <0x8>;
			bias-pull-down;
		};
	};


	qpic_snand_default_state: qpic-snand-default-state {
		clock-pins {
			pins = "gpio5";
			function = "qspi_clk";
			drive-strength = <8>;
			bias-disable;
		};

		cs-pins {
			pins = "gpio4";
			function = "qspi_cs";
			drive-strength = <8>;
			bias-disable;
		};

		data-pins {
			pins = "gpio0", "gpio1", "gpio2", "gpio3";
			function = "qspi_data";
			drive-strength = <8>;
			bias-disable;
		};
	};

	pcie2_default: pcie2-default-state {
		clkreq-n-pins {
			pins = "gpio28";
			function = "pcie2_clk";
			drive-strength = <6>;
			bias-pull-up;
		};

		perst-n-pins {
			pins = "gpio29";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
			output-low;
		};

		wake-n-pins {
			pins = "gpio30";
			function = "pcie2_wake";
			drive-strength = <6>;
			bias-pull-up;
		};
	};

	mdio_pins: mdio-default-state {
		mdc {
			pins = "gpio38";
			function = "mdc";
			drive-strength = <8>;
			bias-disable;
		};
		mdio {
			pins = "gpio39";
			function = "mdio";
			drive-strength = <8>;
			bias-pull-up;
		};
	};

	QCC710_pins {
		uart4_pins: blsp1_uart4_pinmux {
			pins = "gpio50", "gpio51", "gpio52", "gpio53";
			function = "blsp4_uart";
			drive-strength = <0x8>;
			bias-disable;
		};

		QCC710_reset {
			pins = "gpio19";
			function = "gpio";
			drive-strength = <0x8>;
			bias-pull-down;
		};
	};

	pta_QCC710 {
		pta1_0 {
			pins = "gpio56";
			function = "pta1_0";
			drive-strength = <0x8>;
			bias-disable;
		};

		pta1_1 {
			pins = "gpio54";
			function = "pta1_1";
			drive-strength = <0x8>;
			bias-disable;
		};

		pta1_2 {
			pins = "gpio55";
			function = "pta1_2";
			drive-strength = <0x8>;
			bias-disable;
		};
	};

};

&mdio {
	status = "okay";
	clock-frequency = <6250000>;
	pinctrl-0 = <&mdio_pins>;
	pinctrl-names = "default";
	phy-reset-gpio = <&tlmm 60 GPIO_ACTIVE_LOW>;
	phyaddr_fixup = <0xC90F018>;
	uniphyaddr_fixup = <0xC90F014>;

	phyaddr_fixup_fix = <0x320c41>;
	uniphyaddr_fixup_fix = <0x1cc5>;

	mdio_clk_fixup; /* MDIO clock sequence fix up flag */

#if 1
	phy0: ethernet-phy@0 {
		      reg = <1>;
		      fixup;
	      };
	phy1: ethernet-phy@1 {
		      reg = <2>;
		      fixup;
	      };
	phy2: ethernet-phy@2 {
		      reg = <3>;
		      fixup;
	      };
	phy3: ethernet-phy@3 {
		      reg = <4>;
		      fixup;
	      };
/*	phy4: ethernet-phy@4 {
		      compatible ="ethernet-phy-ieee802.3-c45";
		      reg = <8>;
	      };
	phy5: ethernet-phy@5 {
		      compatible ="ethernet-phy-ieee802.3-c45";
		      reg = <0>;
	      };*/
#endif

/*	phy4: ethernet-phy@4 {
		      compatible ="ethernet-phy-ieee802.3-c45";
		      reg = <8>;
	      };
	phy5: ethernet-phy@5 {
		      compatible ="ethernet-phy-ieee802.3-c45";
		      reg = <0>;
	      };*/

};

&qpic_bam {
	status = "okay";
};

&qpic_nand {
	pinctrl-0 = <&qpic_snand_default_state>;
	pinctrl-names = "default";
	status = "okay";

	flash@0 {
		reg = <0>;
		compatible = "spi-nand";
		#address-cells = <1>;
		#size-cells = <1>;
		nand-ecc-strength = <8>;
		nand-ecc-step-size = <512>;
		nand-bus-width = <0x08>;
		nand-ecc-engine = <&qpic_nand>;
		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;
			partition@0 {
				label = "sbl1";
				reg = <0x0 0x100000>;
				read-only;
			};
			partition@20000 {
				label = "sbl_1";
				reg = <0x100000 0x100000>;
				read-only;
			};

			partition@200000 {
				label = "mibib";
				reg = <0x200000 0x100000>;
				read-only;
			};

			partition@300000 {
				label = "bootconfig";
				reg = <0x300000 0x80000>;
				read-only;
			};

			partition@380000 {
				label = "bootconfig1";
				reg = <0x380000 0x80000>;
				read-only;
			};

			partition@400000 {
				label = "qsee";
				reg = <0x400000 0x200000>;
				read-only;
			};

			partition@600000 {
				label = "qsee_1";
				reg = <0x600000 0x200000>;
				read-only;
			};

			partition@800000 {
				label = "devcfg";
				reg = <0x800000 0x80000>;
				read-only;
			};

			partition@880000 {
				label = "devcfg_1";
				reg = <0x880000 0x80000>;
				read-only;
			};

			partition@900000 {
				label = "apdp";
				reg = <0x900000 0x80000>;
				read-only;
			};

			partition@980000 {
				label = "apdp_1";
				reg = <0x980000 0x80000>;
				read-only;
			};

			partition@a00000 {
				label = "tme";
				reg = <0xa00000 0x80000>;
				read-only;
			};

			partition@a80000 {
				label = "tme_1";
				reg = <0xa80000 0x80000>;
				read-only;
			};

			partition@b00000 {
				label = "rpm";
				reg = <0xb00000 0x80000>;
				read-only;
			};

			partition@b80000 {
				label = "rpm_1";
				reg = <0xb80000 0x80000>;
				read-only;
			};

			partition@c00000 {
				label = "cdt";
				reg = <0xc00000 0x80000>;
				read-only;
			};

			partition@c80000 {
				label = "cdt_1";
				reg = <0xc80000 0x80000>;
				read-only;
			};

			partition@d00000 {
				label = "appsblenv";
				reg = <0xd00000 0x80000>;
			};

			partition@d80000 {
				label = "appsbl";
				reg = <0xd80000 0x100000>;
				read-only;
			};

			partition@e80000 {
				label = "appsbl_1";
				reg = <0xe80000 0x100000>;
				read-only;
			};

			partition@f80000 {
				label = "art";
				reg = <0xf80000 0x100000>;
				read-only;
			};

			partition@1080000 {
				label = "training";
				reg = <0x1080000 0x80000>;
			};

			partition@1100000 {
				label = "license";
				reg = <0x1100000 0x40000>;
			};

			partition@1140000 {
				label = "rootfs";
				reg = <0x1140000 0x2800000>;
			};

			partition@3940000 {
				label = "rootfs_1";
				reg = <0x3940000 0x2800000>;
			};

			partition@6140000 {
				label = "bdata";
				reg = <0x6140000 0x80000>;
			};

			partition@61c0000 {
				label = "nvram";
				reg = <0x61c0000 0x100000>;
				
			};

			partition@62c0000 {
				label = "overlay";
				reg = <0x62c0000 0x1c00000>;
				
			};

			partition@7ec0000 {
				label = "kf";
				reg = <0x7ec0000 0x40000>;
				
			};
		};

	};
};


&soc {
	ess-uniphy@7a00000 {
		compatible = "qcom,ess-uniphy";
		reg = <0x7a00000 0x30000>;
		uniphy_access_mode = "local bus";
	};

	ess_instance: ess-instance {
		compatible = "qcom,ess-instance";
		#address-cells = <1>;
		#size-cells = <1>;

		switch: ess-switch@3a000000 {

			compatible = "qcom,ess-switch-ipq95xx";
			switch_access_mode = "local bus";
			reg = <0x3a000000 0x1000000>;

			interconnects = <&nsscc MASTER_NSSNOC_PPE
					 &nsscc SLAVE_NSSNOC_PPE>,
					<&nsscc MASTER_NSSNOC_PPE_CFG
					 &nsscc SLAVE_NSSNOC_PPE_CFG>,
					<&gcc MASTER_NSSNOC_QOSGEN_REF
					 &gcc SLAVE_NSSNOC_QOSGEN_REF>,
					<&gcc MASTER_NSSNOC_TIMEOUT_REF
					 &gcc SLAVE_NSSNOC_TIMEOUT_REF>,
					<&gcc MASTER_MEM_NOC_NSSNOC
					 &gcc SLAVE_MEM_NOC_NSSNOC>,
					<&gcc MASTER_NSSNOC_MEMNOC
					 &gcc SLAVE_NSSNOC_MEMNOC>,
					<&gcc MASTER_NSSNOC_MEM_NOC_1
					 &gcc SLAVE_NSSNOC_MEM_NOC_1>;
			interconnect-names = "ppe",
					     "ppe_cfg",
					     "qos_gen",
					     "timeout_ref",
					     "nssnoc_memnoc",
					     "memnoc_nssnoc",
					     "memnoc_nssnoc_1";



			clocks = <&gcc GCC_CMN_12GPLL_AHB_CLK>,
				<&gcc GCC_CMN_12GPLL_SYS_CLK>,
				<&gcc GCC_UNIPHY0_AHB_CLK>,
				<&gcc GCC_UNIPHY0_SYS_CLK>,
				<&gcc GCC_UNIPHY1_AHB_CLK>,
				<&gcc GCC_UNIPHY1_SYS_CLK>,
				<&gcc GCC_UNIPHY2_AHB_CLK>,
				<&gcc GCC_UNIPHY2_SYS_CLK>,
				<&gcc GCC_NSSNOC_NSSCC_CLK>,
				<&gcc GCC_NSSCC_CLK>,
				<&gcc GCC_NSSNOC_SNOC_1_CLK>,
				<&gcc GCC_NSSNOC_SNOC_CLK>,
				<&nsscc NSS_CC_PORT1_MAC_CLK>,
				<&nsscc NSS_CC_PORT2_MAC_CLK>,
				<&nsscc NSS_CC_PORT3_MAC_CLK>,
				<&nsscc NSS_CC_PORT4_MAC_CLK>,
				<&nsscc NSS_CC_PORT5_MAC_CLK>,
				<&nsscc NSS_CC_PORT6_MAC_CLK>,
				<&nsscc NSS_CC_PPE_SWITCH_CLK>,
				<&nsscc NSS_CC_PPE_SWITCH_CFG_CLK>,
