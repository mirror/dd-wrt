/dts-v1/;

#include "rtl931x.dtsi"

#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	compatible = "edgecore,ecs4125-10p", "realtek,rtl838x-soc";
	model = "Edgecore ECS4125-10P Switch";

	aliases {
		led-boot = &led_sys;
		led-failsafe = &led_sys;
		led-running = &led_sys;
		led-upgrade = &led_sys;
	};	


	memory@0 {
		device_type = "memory";
		reg = <0x0 0x10000000>;
	};

	memory@90000000 {
		device_type = "memory";
		reg = <0x90000000 0x30000000>;
	};

	chosen {
		bootargs = "console=ttyS0,115200";
	};

	leds {
		compatible = "gpio-leds";

		led_sys: sys {
			label = "ecs4125_15:green:sys";
			gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
		};
	};


	sfp0: sfp-p9 {
		compatible = "sff,sfp";
		i2c-bus = <&i2c0>;
		los-gpio = <&gpio0 29 GPIO_ACTIVE_HIGH>;
		tx-fault-gpio = <&gpio0 30 GPIO_ACTIVE_HIGH>;
		mod-def0-gpio = <&gpio0 28 GPIO_ACTIVE_LOW>;
//		tx-disable-gpio = <&gpio0 31 GPIO_ACTIVE_HIGH>;
	};

	sfp1: sfp-p10 {
		compatible = "sff,sfp";
		i2c-bus = <&i2c1>;
		los-gpio = <&gpio0 25 GPIO_ACTIVE_HIGH>;
		tx-fault-gpio = <&gpio0 26 GPIO_ACTIVE_HIGH>;
		mod-def0-gpio = <&gpio0 24 GPIO_ACTIVE_LOW>;
//		tx-disable-gpio = <&gpio0 27 GPIO_ACTIVE_HIGH>;
	};
/*
&gpio0 {
	indirect-access-bus-id = <0>;
	};
*/
};

&i2c_mst1 {
	status = "okay";

	/* i2c of the left SFP+ cage seen from the front; port 11 */
	i2c0: i2c@0 {
		reg = <0>;
	};

	/* i2c of the right SFP+ cage seen from the front; port 12 */
	i2c1: i2c@1 {
		reg = <1>;
	};

	i2c2: i2c@2 { reg = <2>; };

	i2c3: i2c@3 { reg = <3>; };

	i2c4: i2c@4 { reg = <4>; };

	i2c5: i2c@5 { reg = <5>; };

};

&spi0 {
	status = "okay";
	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <10000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x0 0x100000>;
			};
			partition@100000 {
				label = "u-boot-env";
				reg = <0x100000 0x10000>;
			};
			partition@120000 {
				label = "jffs";
				reg = <0x120000 0x100000>;
			};
			partition@220000 {
				label = "jffs2";
				reg = <0x220000 0x100000>;
			};
			partition@320000 {
				label = "linux";
				reg = <0x320000 0x1e60000>;
				compatible = "openwrt,uimage", "denx,uimage";
			};
			partition@2180000 {
				label = "nvram";
				reg = <0x2180000 0x20000>;
			};
			partition@2200000 {
				label = "runtime2";
				reg = <0x2200000 0x1e00000>;
			};
		};
	};
};

&mdio_ctrl {
	pinctrl-names = "default";
	pinctrl-0 = <&pinmux_enable_mdc_mdio_0>,
		    <&pinmux_enable_mdc_mdio_1>;
};

&mdio_bus0 {
	PHY_C45(0, 4)
	PHY_C45(8, 2)
	PHY_C45(16, 6)
	PHY_C45(24, 1)
};
&mdio_bus1 {
	PHY_C45(32, 4)
	PHY_C45(40, 2)
	PHY_C45(48, 6)
	PHY_C45(50, 1)
};

&switch0 {
	ethernet-ports {
		#address-cells = <1>;
		#size-cells = <0>;


		SWITCH_PORT_SDS(0, 2, 2, hsgmii)
		SWITCH_PORT_SDS(8, 1, 3, hsgmii)
		SWITCH_PORT_SDS(16, 4, 4, hsgmii)
		SWITCH_PORT_SDS(24, 3, 5, hsgmii)
		SWITCH_PORT_SDS(32, 5, 6, hsgmii)
		SWITCH_PORT_SDS(40, 6, 7, hsgmii)
		SWITCH_PORT_SDS(48, 7, 8, hsgmii)
		SWITCH_PORT_SDS(50, 8, 9, hsgmii)

		SWITCH_PORT_SFP(54, 9, 12, 0, 0)
		SWITCH_PORT_SFP(55, 10, 13, 0, 1)

		/* CPU port */
		port@56 {
			ethernet = <&ethernet0>;
			reg = <56>;
			phy-mode = "internal";
			fixed-link {
				speed = <1000>;
				full-duplex;
			};
		};
	};
};
